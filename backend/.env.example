PORT=3001
NODE_ENV=development

# true = SQLite local (backend/data/inventario.sqlite)
# false = Supabase — obligatorio en Render Free para datos persistentes
DEMO_MODE=true

# Supabase — proyecto herramientas (ref: lxkkguclaumcjxksjywh)
# Settings → API → Project URL + service_role / secret (no publishable)
SUPABASE_URL=https://lxkkguclaumcjxksjywh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Solo para npm run db:apply-patch (contraseña de Database, no la API secret)
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.lxkkguclaumcjxksjywh.supabase.co:5432/postgres

# Umbral stock bajo (dashboard)
LOW_STOCK_THRESHOLD=2

# CORS — orígenes permitidos (separados por coma)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://192.168.1.100:5173

# Producción Render + Vercel:
# FRONTEND_URL=https://control-de-stock-smoky.vercel.app
# CORS_ORIGINS=https://control-de-stock-smoky.vercel.app
# NODE_ENV=production

# Administrador (alta/baja de ítems en stock)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=Administrador
JWT_SECRET=cambiar-este-secreto-en-produccion
